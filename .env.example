# Service API key — callers must send: Authorization: Bearer <API_KEY>
# Generate with: node -e "import('crypto').then(c => console.log(c.randomBytes(32).toString('hex')))"
API_KEY=

# Secret used by Vercel to authenticate cron job requests
# Set this in Vercel Dashboard → Settings → Environment Variables
# Generate with: node -e "import('crypto').then(c => console.log(c.randomBytes(32).toString('hex')))"
CRON_SECRET=

# Gmail — Google Account → Security → 2-Step Verification → App Passwords → generate for "Mail"
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=

# Supabase (same project as portfolio-tracker / aggregator-service)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PORT=3002
