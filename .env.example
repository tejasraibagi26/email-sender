# Service API key — callers must send: Authorization: Bearer <API_KEY>
# Generate with: node -e "import('crypto').then(c => console.log(c.randomBytes(32).toString('hex')))"
API_KEY=

# Resend — from resend.com → API Keys
RESEND_API_KEY=

# Supabase (same project as portfolio-tracker / aggregator-service)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# QStash — from console.upstash.com → QStash
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

PORT=3002
